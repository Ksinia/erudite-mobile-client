{
  "name": "client-react-native",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start-on-ios-simulator": "xcrun simctl shutdown all 2>/dev/null; xcrun simctl boot \"iPhone 16 Pro Max\"; expo start --dev-client --ios",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "eas build --platform ios --profile development && expo start --dev-client",
    "ios-preview": "eas build --platform ios --profile preview && expo start --dev-client",
    "ios-simulator": "eas build --platform ios --profile development-simulator && expo start --dev-client",
    "install-build-on-simulator": "eas build:run --profile development-simulator --platform ios",
    "update-simulator-build": "eas update --environment development --channel development-simulator --message",
    "update-preview-build": "eas update --environment preview --channel preview",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "/node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|immer)",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.0.14",
    "@reduxjs/toolkit": "^2.3.0",
    "expo": "^53.0.0",
    "expo-apple-authentication": "~7.2.4",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-localization": "~16.1.6",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "react-redux": "^9.1.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.0.10",
    "@types/ws": "^8.18.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.2.1",
    "jest-expo": "~53.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "react-server-dom-webpack": "19.0.0",
    "react-test-renderer": "19.0.0",
    "engine.io-client": {
      "ws": "8.21.0"
    }
  },
  "private": true
}
